---
// SolarSystem component - Three.js 星系背景
---

<div id="solar-system-container" class="fixed inset-0 z-0">
  <canvas id="solar-canvas"></canvas>
  <output id="camera-position" aria-live="polite"></output>
</div>
<div id="solar-loader" role="status" aria-live="polite">
  <span class="loader-mark" aria-hidden="true"></span>
  <span id="solar-loader-text">正在下载 Three.js 环境……</span>
</div>

<script>
  let cleanup: (() => void) | undefined;
  let loadGeneration = 0;

  document.addEventListener('astro:page-load', async () => {
    cleanup?.();
    cleanup = undefined;

    const generation = ++loadGeneration;
    const canvas = document.getElementById('solar-canvas') as HTMLCanvasElement;
    const loader = document.getElementById('solar-loader');
    const loaderText = document.getElementById('solar-loader-text');
    if (!canvas) {
      return;
    }

    loaderText && (loaderText.textContent = '正在下载 Three.js 环境');
    const { initSolarSystem } = await import('../scripts/solarSystem');
    if (generation !== loadGeneration || !canvas.isConnected) {
      return;
    }

    const stageLabels = {
      model: '正在下载模型……',
      shaders: '正在编译着色器……',
      ready: '加载完成……',
    } as const;
    const dispose = await initSolarSystem(canvas, {
      onLoadStage: (stage) => {
        if (generation === loadGeneration && loaderText) {
          loaderText.textContent = stageLabels[stage];
        }
      },
    });

    if (generation !== loadGeneration || !canvas.isConnected) {
      dispose();
      return;
    }

    cleanup = dispose;
    canvas.classList.add('is-ready');
    loader?.classList.add('is-complete');
  });

  document.addEventListener('astro:before-swap', () => {
    loadGeneration += 1;
    cleanup?.();
    cleanup = undefined;
  });
</script>

<style>
  #solar-system-container {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  :global(.project-transition-space) {
    animation: depart-upward var(--motion-duration-slow) var(--motion-ease) forwards;
    will-change: transform, opacity;
  }

  :global(.project-transition-content) {
    animation: fade-for-departure var(--motion-duration) var(--motion-ease-exit) forwards;
    pointer-events: none;
  }

  @keyframes depart-upward {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateY(-32vh) scale(1.08);
    }
  }

  @keyframes fade-for-departure {
    to {
      opacity: 0;
      transform: translateY(-24px);
    }
  }


  #solar-canvas {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1200ms var(--motion-ease);
  }

  #solar-canvas.is-ready {
    opacity: 1;
  }

  #solar-loader {
    position: fixed;
    z-index: 30;
    bottom: 1.5rem;
    left: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: rgb(255 255 255 / 62%);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    transition: opacity 600ms var(--motion-ease);
    pointer-events: none;
  }

  #solar-loader.is-complete {
    opacity: 0;
    transition-delay: 500ms;
  }

  .loader-mark {
    width: 0.38rem;
    height: 0.38rem;
    background: currentColor;
    border-radius: 50%;
    animation: loader-pulse 1200ms ease-in-out infinite;
  }

  @keyframes loader-pulse {
    50% {
      opacity: 0.25;
      transform: scale(0.7);
    }
  }

  #camera-position {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    color: rgba(255, 255, 255, 0.65);
    font-family: monospace;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    pointer-events: none;
  }

  :global(.solar-tooltip) {
    position: fixed;
    z-index: 1000;
    padding: 0.5rem 0.75rem;
    color: white;
    font-size: 0.875rem;
    pointer-events: none;
    background: rgb(0 0 0 / 80%);
    border: 1px solid rgb(255 255 255 / 20%);
    border-radius: 0.375rem;
    backdrop-filter: blur(4px);
  }

</style>
