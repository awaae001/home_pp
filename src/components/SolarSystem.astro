---
// SolarSystem component - Three.js 太阳系背景
---

<div id="solar-system-container" class="fixed inset-0 z-0">
  <canvas id="solar-canvas"></canvas>
</div>

<div class="fixed inset-0 z-5 bg-linear-to-b from-transparent via-[#0d1117]/50 to-[#0d1117]/80 pointer-events-none"></div>

<script>
  import { initSolarSystem } from '../scripts/solarSystem';

  let cleanup: (() => void) | undefined;

  document.addEventListener('astro:page-load', () => {
    if (cleanup) {
      cleanup();
      cleanup = undefined;
    }
    const canvas = document.getElementById('solar-canvas') as HTMLCanvasElement;
    if (canvas) {
      cleanup = initSolarSystem(canvas);
    }
  });

  document.addEventListener('astro:before-swap', () => {
    if (cleanup) {
      cleanup();
      cleanup = undefined;
    }
  });
</script>

<style>
  #solar-system-container {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  #solar-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
