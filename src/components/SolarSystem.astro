---
// SolarSystem component - Three.js 星系背景
---

<div id="solar-system-container" class="fixed inset-0 z-0">
  <canvas id="solar-canvas"></canvas>
  <output id="camera-position" aria-live="polite"></output>
</div>

<script>
  let cleanup: (() => void) | undefined;
  let loadGeneration = 0;

  document.addEventListener('astro:page-load', async () => {
    cleanup?.();
    cleanup = undefined;

    const generation = ++loadGeneration;
    const canvas = document.getElementById('solar-canvas') as HTMLCanvasElement;
    if (!canvas) {
      return;
    }

    const { initSolarSystem } = await import('../scripts/solarSystem');
    if (generation !== loadGeneration || !canvas.isConnected) {
      return;
    }

    cleanup = initSolarSystem(canvas);
  });

  document.addEventListener('astro:before-swap', () => {
    loadGeneration += 1;
    cleanup?.();
    cleanup = undefined;
  });
</script>

<style>
  #solar-system-container {
    width: 100vw;
    height: 100vh;
    overflow: hidden;
  }

  :global(.project-transition-space) {
    animation: depart-upward var(--motion-duration-slow) var(--motion-ease) forwards;
    will-change: transform, opacity;
  }

  :global(.project-transition-content) {
    animation: fade-for-departure var(--motion-duration) var(--motion-ease-exit) forwards;
    pointer-events: none;
  }

  @keyframes depart-upward {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateY(-32vh) scale(1.08);
    }
  }

  @keyframes fade-for-departure {
    to {
      opacity: 0;
      transform: translateY(-24px);
    }
  }


  #solar-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  #camera-position {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    color: rgba(255, 255, 255, 0.65);
    font-family: monospace;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    pointer-events: none;
  }

  :global(.solar-tooltip) {
    position: fixed;
    z-index: 1000;
    padding: 0.5rem 0.75rem;
    color: white;
    font-size: 0.875rem;
    pointer-events: none;
    background: rgb(0 0 0 / 80%);
    border: 1px solid rgb(255 255 255 / 20%);
    border-radius: 0.375rem;
    backdrop-filter: blur(4px);
  }

</style>
