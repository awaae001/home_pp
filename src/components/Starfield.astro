---
// Mounts the site's shared deep-space background.
---

<div class="starfield" aria-hidden="true">
  <canvas id="project-starfield"></canvas>
</div>

<script>
  let disposeStarfield: (() => void) | undefined;
  let loadGeneration = 0;

  document.addEventListener("astro:page-load", async () => {
    disposeStarfield?.();
    disposeStarfield = undefined;

    const generation = ++loadGeneration;
    const canvas = document.getElementById("project-starfield");
    if (!(canvas instanceof HTMLCanvasElement)) {
      return;
    }

    const { initStarfield } = await import("../scripts/starfield");
    if (generation !== loadGeneration || !canvas.isConnected) {
      return;
    }

    disposeStarfield = initStarfield(canvas);
    canvas.classList.add('is-ready');
  });

  document.addEventListener("astro:before-swap", () => {
    loadGeneration += 1;
    disposeStarfield?.();
    disposeStarfield = undefined;
  });
</script>

<style>
  .starfield {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
    background: transparent;
  }

  canvas {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 1200ms var(--motion-ease);
  }

  canvas.is-ready {
    opacity: 1;
  }
</style>
