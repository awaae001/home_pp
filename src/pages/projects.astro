---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Starfield from "../components/Starfield.astro";
import Layout from "../layouts/Layout.astro";

const projects = (await getCollection("projects")).sort(
  (left, right) => left.data.order - right.data.order,
);

const statusLabels = {
  online: "运行中",
  building: "建造中",
  archived: "已归档",
} as const;
---

<Layout
  title="awaae001 · 项目"
  description="项目与代码档案。"
  canonicalPath="/projects"
>
  <Starfield />

  <div class="fixed top-6 right-6 z-20 flex gap-4" style="animation: reveal-down var(--motion-duration) var(--motion-ease) both;">
    <a
      href="/"
      title="返回"
      class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white rounded-lg backdrop-blur-sm border border-white/20 transition-all duration-500 hover:scale-105 cursor-pointer flex items-center justify-center"
    >
      <Icon name="mdi:arrow-left" class="w-4 h-4" />
    </a>
  </div>

  <main class="project-page">
    <section class="layout-section console-section" aria-label="项目列表">
      <div class="console">
        <div class="console-head" aria-hidden="true">
          <span>编号 / 项目</span>
          <span>技术栈</span>
          <span>年份 / 状态</span>
          <span>链接</span>
        </div>
        {
          projects.map(({ data }, index) => (
            <article
              class="console-row"
              data-accent={data.accent}
              style={`--enter-delay:${180 + index * 70}ms`}
            >
              <div class="project-identity">
                <span class="project-code">{data.code}</span>
                <div>
                  <h3>{data.name}</h3>
                  <p>{data.summary}</p>
                </div>
              </div>
              <ul class="tech-list" aria-label={`${data.name} 技术栈`}>
                {data.technologies.map((technology) => <li>{technology}</li>)}
              </ul>
              <div class="status-cell">
                <span>{data.year}</span>
                <span class="status">
                  <i></i>
                  {statusLabels[data.status]}
                </span>
              </div>
              <div class="project-actions">
                {data.repository && (
                  <a href={data.repository} target="_blank" rel="noreferrer" aria-label={`${data.name} 源代码`}>
                    <Icon name="mdi:github" class="h-5 w-5" />
                  </a>
                )}
                {data.website && (
                  <a href={data.website} target="_blank" rel="noreferrer" aria-label={`打开 ${data.name} 网站`}>
                    <Icon name="mdi:arrow-top-right" class="h-5 w-5" />
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </section>

  </main>
</Layout>

<style>
  :global(body) {
    overflow-x: hidden;
  }

  .project-page {
    --line: rgb(255 255 255 / 10%);
    --muted: #8792a2;
    position: relative;
    z-index: 1;
    width: min(1180px, calc(100% - 40px));
    margin: 0 auto;
    padding-bottom: 9rem;
    color: #edf5ff;
    font-family: Inter, ui-sans-serif, system-ui, sans-serif;
  }

  .layout-section {
    padding: clamp(2.5rem, 6vw, 4.5rem) 0;
  }

  [data-accent="cyan"] { --accent: #6cd8ff; --accent-rgb: 108 216 255; }
  [data-accent="violet"] { --accent: #a98cff; --accent-rgb: 169 140 255; }
  [data-accent="amber"] { --accent: #ffc56c; --accent-rgb: 255 197 108; }
  [data-accent="rose"] { --accent: #ff829f; --accent-rgb: 255 130 159; }

  .console {
    width: 100%;
  }

  .console-head,
  .console-row {
    display: grid;
    grid-template-columns: minmax(0, 2.1fr) minmax(180px, 0.8fr) 140px 90px;
    gap: 1.5rem;
    align-items: center;
  }

  .console-head {
    padding: 0.9rem 1.25rem;
    color: #596575;
    border-bottom: 1px solid var(--line);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.13em;
    animation: reveal-up var(--motion-duration) var(--motion-ease) 100ms both;
  }

  .console-row {
    position: relative;
    padding: 1.5rem 1.25rem;
    border-bottom: 1px solid var(--line);
    animation: reveal-up var(--motion-duration) var(--motion-ease) var(--enter-delay) both;
    transition: background var(--motion-duration-fast) var(--motion-ease);
  }

  .console-row:last-child {
    border-bottom: 0;
  }

  .console-row:hover {
    background: rgb(var(--accent-rgb) / 4%);
  }

  .project-identity {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 0.8rem;
  }

  .project-code {
    padding-top: 0.3rem;
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.62rem;
  }

  .project-identity h3 {
    margin-bottom: 0.35rem;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .project-identity p {
    color: #7f8a99;
    font-size: 0.8rem;
    line-height: 1.65;
  }

  .tech-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .tech-list li {
    padding: 0.28rem 0.5rem;
    color: #8c98a7;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.6rem;
  }

  .status-cell {
    display: grid;
    gap: 0.45rem;
    color: #9aa6b5;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.68rem;
  }

  .status {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: #687484;
  }

  .status i {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 9px var(--accent);
  }

  .project-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.55rem;
  }

  .project-actions a {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    color: #7d8998;
    border: 1px solid var(--line);
    border-radius: 50%;
    transition:
      color var(--motion-duration-fast) var(--motion-ease),
      border-color var(--motion-duration-fast) var(--motion-ease),
      background var(--motion-duration-fast) var(--motion-ease),
      transform var(--motion-duration-fast) var(--motion-ease);
  }

  .project-actions a:hover {
    color: #071018;
    border-color: var(--accent);
    background: var(--accent);
    transform: translateY(-2px);
  }

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes reveal-down {
    from {
      opacity: 0;
      transform: translateY(-12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 800px) {
    .project-page {
      width: min(100% - 28px, 1180px);
    }

    .console-head {
      display: none;
    }

    .console-row {
      grid-template-columns: 1fr auto;
      gap: 1.25rem;
    }

    .project-identity,
    .tech-list {
      grid-column: 1;
    }

    .status-cell {
      grid-column: 1;
    }

    .project-actions {
      grid-column: 2;
      grid-row: 1 / span 3;
      flex-direction: column;
    }

  }

  @media (max-width: 520px) {
    .project-identity {
      grid-template-columns: 1fr;
    }

  }
</style>
