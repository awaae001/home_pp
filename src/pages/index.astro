---
import Layout from "../layouts/Layout.astro";
import SolarSystem from "../components/SolarSystem.astro";
import Link from '../components/ui/Link.astro';
import { Icon } from "astro-icon/components";
---

<Layout>
	<SolarSystem />
	<div id="main-mask" class="fixed inset-0 z-10 bg-[#0d1117]/60 backdrop-blur-[2px] transition-opacity duration-500"></div>
	<div id="main-content" class="relative z-20 flex flex-col h-screen transition-opacity duration-500">
		<div class="grow">
			<div class="relative w-full h-full overflow-hidden font-sans">
				<main class="flex flex-col items-center justify-center h-full px-4 text-right">
					<section class="space-y-8">
						<h1 class="text-1xl md:text-5xl font-bold text-white tracking-tight animate-fade-in">
							👋你好，我是 awaae001
						</h1>
						<p class="text-base md:text-lg text-gray-300 animate-fade-in opacity-0" style="animation-delay: 0.15s; animation-fill-mode: forwards;">
							新时代，最重要的不再是知识，而是判断，还有审美
						</p>
						
						<div class="flex flex-wrap items-center justify-end gap-4 animate-fade-in-up">
							<Link 
								text="Blog" 
								href="https://blog.awaae001.top" 
								icon="mdi:pen"
								variant="capsule" 
								external={true}
							/>
							<Link 
								id="btn-website"
								text="星图" 
								href="#" 
								icon="mdi:web" 
								variant="article" 
							/>
							<Link 
								text="关于" 
								href="/about" 
								variant="article" 
							/>
						</div>
					</section>
				</main>
			</div>
		</div>
	</div>

	<div class="fixed top-6 right-6 z-20 flex gap-4">
		<button
			id="btn-reset-view"
			class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white rounded-lg backdrop-blur-sm border border-white/20 transition-all duration-500 opacity-0 pointer-events-none hover:scale-105 cursor-pointer flex items-center gap-2"
		>
			<Icon name="mdi:refresh" class="w-4 h-4" />
			重置视角
		</button>
		<button
			id="btn-back"
			title="返回"
			class="px-4 py-2 bg-white/10 hover:bg-white/20 text-white rounded-lg backdrop-blur-sm border border-white/20 transition-all duration-500 opacity-0 pointer-events-none hover:scale-105 cursor-pointer flex items-center justify-center"
		>
			<Icon name="mdi:arrow-left" class="w-4 h-4" />
		</button>
	</div>
</Layout>

<style>
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(-10px); }
		to { opacity: 1; transform: translateY(0); }
	}
	
	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.animate-fade-in {
		animation: fadeIn 0.8s ease-out forwards;
	}

	.animate-fade-in-up {
		animation: fadeInUp 0.8s ease-out 0.3s forwards;
		opacity: 0;
	}
</style>

<script>
	document.addEventListener('astro:page-load', () => {
		const btnWebsite = document.getElementById('btn-website');
		const btnBack = document.getElementById('btn-back');
		const btnReset = document.getElementById('btn-reset-view');
		const mainContent = document.getElementById('main-content');
		const mainMask = document.getElementById('main-mask');

		if (btnWebsite && btnBack && btnReset && mainContent && mainMask) {
			btnWebsite.addEventListener('click', (e) => {
				e.preventDefault();
				mainContent.style.opacity = '0';
				mainContent.style.pointerEvents = 'none';
				mainMask.style.opacity = '0';
				mainMask.style.pointerEvents = 'none';
				
				btnBack.style.opacity = '1';
				btnBack.style.pointerEvents = 'auto';
				btnReset.style.opacity = '1';
				btnReset.style.pointerEvents = 'auto';
			});

			btnBack.addEventListener('click', () => {
				mainContent.style.opacity = '1';
				mainContent.style.pointerEvents = 'auto';
				mainMask.style.opacity = '1';
				mainMask.style.pointerEvents = 'auto';
				
				btnBack.style.opacity = '0';
				btnBack.style.pointerEvents = 'none';
				btnReset.style.opacity = '0';
				btnReset.style.pointerEvents = 'none';
			});
		}
	});
</script>
